<Window x:Class="ICare.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="ICare" Height="500" Width="750"
        WindowStyle="SingleBorderWindow"
        Icon="pack://application:,,,/eye.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        

        <Border Grid.Column="0" Background="#EDE8E0" Padding="12,24,12,24">
            <StackPanel>
                <Button x:Name="NavOverview" Content="Overview"
                        Click="NavOverview_Click"
                        Margin="0,0,0,4"
                        Style="{StaticResource NavButtonActive}"/>
                <Button x:Name="NavSettings" Content="Settings"
                        Click="NavSettings_Click"
                        Margin="0,0,0,4"
                        Style="{StaticResource NavButton}"/>
            </StackPanel>
        </Border>

        <ContentControl x:Name="ContentArea" Grid.Column="1"/>
    </Grid>
</Window>