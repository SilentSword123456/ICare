<UserControl x:Class="ICare.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F0E8">
    <Grid Margin="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="160"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Width="180" Height="180">
                <Canvas Width="180" Height="180">
                    <Ellipse Canvas.Left="4" Canvas.Top="4"
                             Width="172" Height="172"
                             Stroke="#DDD8D0" StrokeThickness="8"
                             Fill="Transparent"/>
                    <Path x:Name="TimerArc"
                          Stroke="#2D5A3D" StrokeThickness="8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"/>
                </Canvas>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="CountdownLabel" Text="20:00"
                               Foreground="#2D2D2D" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="until break" Foreground="#8B8B8B" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="SkipStatusLabel" Text="Break scheduled"
                       Foreground="#8B8B8B" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <Border Background="#EDE8E0" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="WORK" Foreground="#8B8B8B" FontSize="10"/>
                    <TextBlock x:Name="WorkLabel" Text="20"
                               Foreground="#2D2D2D" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="minutes" Foreground="#8B8B8B" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Background="#EDE8E0" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="BREAK" Foreground="#8B8B8B" FontSize="10"/>
                    <TextBlock x:Name="BreakLabel" Text="20"
                               Foreground="#2D2D2D" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="seconds" Foreground="#8B8B8B" FontSize="11"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>